{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@lib/*": ["./src/lib/*"],
    },
    "strictNullChecks": true,
    "target": "ESNext",
  },
  "include": [
    "./src/**/*",
    "./eslint.config.ts",
    "./vite.config.ts",
  ],
  "allowDefaultProject": ["./eslint.config.mjs"]
}
